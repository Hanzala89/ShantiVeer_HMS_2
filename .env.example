# ─── Django Core ──────────────────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-50-char-random-secret-key
DJANGO_DEBUG=False
ALLOWED_HOSTS=yourapp.vercel.app

# ─── Database (PostgreSQL — required, SQLite not supported) ───────────────────
# Get a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Redis Cache (recommended — get a free instance at https://upstash.com) ───
REDIS_URL=rediss://user:password@host:port

# ─── Email (required for OTP login + password reset) ─────────────────────────
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password
DEFAULT_FROM_EMAIL=your@gmail.com

# ─── CSRF (add your Vercel domain) ────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=https://yourapp.vercel.app

# ─── Security ─────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCKOUT_DURATION=300

# ─── Hospital Info ─────────────────────────────────────────────────────────────
HOSPITAL_NAME=ShantiVeer Hospital
HOSPITAL_ADDRESS=Main Road, City
HOSPITAL_PHONE=9876543210

# ─── Vercel (set automatically by Vercel, add manually for local testing) ─────
# VERCEL=1
