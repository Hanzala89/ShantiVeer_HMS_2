# ─── Django Core ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-chars
DJANGO_DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost

# ─── Database (leave USE_MYSQL=False to use SQLite) ───────────────────────────
USE_MYSQL=False
DB_NAME=ShantiVeer_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ─── Email (required for OTP login + password reset) ─────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your@gmail.com

# ─── Security ────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCKOUT_DURATION=300

# ─── Hospital Info ────────────────────────────────────────────────────────────
HOSPITAL_NAME=SantiVeer Hospital
HOSPITAL_ADDRESS=Main Road, City
HOSPITAL_PHONE=9876543210
